{
  "name": "notion-research-agent",
  "version": "0.2.0",
  "description": "Private operator research workstation for durable Gemini web research and audited Notion writes.",
  "keywords": [
    "nextjs",
    "gemini",
    "notion",
    "mcp",
    "playwright",
    "web-research",
    "human-in-the-loop",
    "private-operator-tool"
  ],
  "private": true,
  "scripts": {
    "status": "node scripts/repo-status.cjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "playwright install chromium",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "verify": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@modelcontextprotocol/sdk": "^1.6.0",
    "@notionhq/notion-mcp-server": "2.2.1",
    "next": "^15.1.0",
    "playwright": "^1.49.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.14",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
