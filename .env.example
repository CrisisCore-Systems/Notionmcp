# Get from https://aistudio.google.com/apikey (free, no credit card)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: enables API-backed web search instead of the built-in DuckDuckGo fallback
SERPER_API_KEY=

# Optional: required only if you intentionally allow remote API access.
# Leave both unset to keep /api/research and /api/write local-only.
# The first-party UI can send this token with its optional "App access token" field.
APP_ALLOWED_ORIGIN=
APP_ACCESS_TOKEN=

# Get from https://www.notion.so/profile/integrations
# Create an internal integration, copy the token
NOTION_TOKEN=ntn_your_notion_token_here

# The Notion page ID where databases will be created
# Open a Notion page → copy the ID from the URL (last 32 chars after the page name)
# e.g. notion.so/My-Page-abc123def456... → abc123def456...
NOTION_PARENT_PAGE_ID=your_notion_page_id_here

# Optional: explicitly pin the Notion API version passed to the local MCP server.
# Defaults to 2025-09-03 to match the pinned @notionhq/notion-mcp-server package.
# Override only when intentionally validating against a newer Notion API version.
NOTION_API_VERSION=2025-09-03
